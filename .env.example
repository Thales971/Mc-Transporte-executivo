# ⚠️ IMPORTANTE: Nunca comite o arquivo .env real com valores!
# Copie este arquivo para .env e preencha com seus valores reais.

# Banco de dados (PostgreSQL hospedado - Neon/Supabase)
DATABASE_URL="postgresql://usuario:senha@host:porta/banco?schema=public"

# URL do site em produção (usado para CORS, SEO, etc.)
# Ex: https://mctransporte.com.br
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Token para acessar o painel admin de avaliações (escolha uma string forte!)
# Ex: uma senha forte como "m1nhaS3nhaS3gura123!"
ADMIN_TOKEN=""

# Google Analytics (opcional — deixe vazio se não quiser usar)
# NEXT_PUBLIC_GA_ID=""

# Chave de Verificação do Google Search Console (opcional — obtida no Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""